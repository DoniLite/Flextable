{
  "name": "flextable",
  "private": true,
  "license": "Apache-2.0",
  "author": "DoniLite",
  "homepage": "https://donilite.github.io/Flextable",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoniLite/Flextable.git"
  },
  "bugs": {
    "url": "https://github.com/DoniLite/Flextable/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "lefthook install",
    "build": "bun run build:core && bun run build:mid && bun run build:crud",
    "build:core": "bun run --filter '@flextable/core' build",
    "build:mid": "bun run --filter '@flextable/react-ui' --filter '@flextable/vue-ui' --filter '@flextable/react' --filter '@flextable/vue' build",
    "build:crud": "bun run --filter '@flextable/react-crud' --filter '@flextable/vue-crud' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun run scripts/rewrite-workspace-protocol.ts && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "latest",
    "@vue/compiler-sfc": "^3.5.0",
    "lefthook": "^2.1.10",
    "typescript": "^7.0.2"
  }
}
