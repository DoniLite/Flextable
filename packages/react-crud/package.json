{
  "name": "@flextable/react-crud",
  "version": "0.1.0",
  "description": "Optional CRUD-dialog glue for @flextable/react: entity editor and async-store hooks, decoupled from any specific backend or toast library via injected adapters.",
  "keywords": [
    "react",
    "crud",
    "table",
    "flextable"
  ],
  "license": "Apache-2.0",
  "author": "DoniLite",
  "homepage": "https://donilite.github.io/Flextable",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoniLite/Flextable.git",
    "directory": "packages/react-crud"
  },
  "bugs": {
    "url": "https://github.com/DoniLite/Flextable/issues"
  },
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --outDir dist",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@flextable/core": "workspace:*",
    "@flextable/react": "workspace:*",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@flextable/core": "workspace:*",
    "@flextable/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^7.0.2"
  }
}
