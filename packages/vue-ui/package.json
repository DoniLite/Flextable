{
  "name": "@flextable/vue-ui",
  "version": "0.1.3",
  "description": "Self-sufficient default Vue UI primitives (reka-ui-based Button/Badge/Checkbox/Avatar/DropdownMenu/...) and entity components for @flextable/vue, fully overridable via slots.",
  "keywords": [
    "vue",
    "ui",
    "components",
    "reka-ui",
    "table",
    "flextable"
  ],
  "license": "Apache-2.0",
  "author": "DoniLite",
  "homepage": "https://donilite.github.io/Flextable",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DoniLite/Flextable.git",
    "directory": "packages/vue-ui"
  },
  "bugs": {
    "url": "https://github.com/DoniLite/Flextable/issues"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/flextable-vue-ui.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && vue-tsc -p tsconfig.build.json --emitDeclarationOnly && vite build && tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@flextable/core": "workspace:*",
    "@lucide/vue": "^1.24.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.7"
  }
}
